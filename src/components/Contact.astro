<section id="contact" class="py-24 px-6 bg-bg-card">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16">
    <div>
      <h2 class="text-5xl md:text-6xl font-mono font-bold tracking-tight leading-none mb-8">
        ¿TENÉS UN PROYECTO O ROL PARA MÍ? <span class="text-accent">ESCRIBIME.</span>
      </h2>
      <div class="flex items-center gap-3 text-text-muted font-mono text-sm mb-12">
        <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <span>San Justo, Santa Fe, Argentina</span>
      </div>
    </div>
    
    <div class="space-y-3">
      {contacts.map(contact => (
        <a 
          href={contact.url} 
          class="flex items-center justify-between p-5 bg-bg-secondary border border-border hover:border-accent transition-colors group"
        >
          <div class="flex items-center gap-4">
            {contact.icon === 'mail' ? (
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox={icons[contact.icon].viewBox}>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icons[contact.icon].path} />
              </svg>
            ) : (
              <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox={icons[contact.icon].viewBox}>
                <path d={icons[contact.icon].path} />
              </svg>
            )}
            <span class="font-mono text-sm">{contact.value}</span>
          </div>
          <svg class="w-5 h-5 text-text-muted opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      ))}
    </div>
  </div>
</section>
