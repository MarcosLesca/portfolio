---
const agronorteProjects = [
  {
    name: 'Titan — Plataforma de Pedidos',
    description: 'Shop interno multiusuario.',
    tags: ['PHP', 'Python', 'JavaScript'],
    confidential: true
  },
  {
    name: 'Repuestos Import Platform',
    description: 'Gestión y seguimiento de importación.',
    tags: ['Django', 'Next.js','TypeScript', 'Postgre SQL', 'Docker'],
    confidential: true
  },
  {
    name: 'Sistema de Balanceos',
    description: 'Automatización de balanceo de stock entre sucursales.',
    tags: ['Python', 'PHP', 'PowerShell'],
    confidential: true
  },
  {
    name: 'Bot de Remesas de Pagos',
    description: 'Automatización de flujo de pagos.',
    tags: ['Python', 'MySQL', 'Shell'],
    confidential: true
  },
  {
    name: 'Agronorte NG — Frontend',
    description: 'Interfaz Angular para gestión interna.',
    tags: ['Angular', 'TypeScript', 'Tailwind CSS', 'Angular Material'],
    confidential: true
  },
  {
    name: 'Agronorte NG — Backend API',
    description: 'API REST en Django.',
    tags: ['Django', 'Python', 'Postgre SQL'],
    confidential: true
  },
  {
    name: 'Tableros de Repuestos',
    description: 'Dashboards de métricas.',
    tags: ['PHP', 'Tailwind CSS', 'MySQL'],
    confidential: true
  }
];

const featuredProjects = [
  {
    name: 'Mascotas San Justo',
    description: 'Plataforma social comunitaria para mascotas perdidas, adopción y donaciones. Panel admin con aprobación de publicaciones, autenticación con límite de intentos, Supabase Storage.',
    tags: ['Next,js', 'Supabase', 'Vite', 'Vercel'],
    public: true,
    demoUrl: 'https://mascotas-social-platform.vercel.app/',
    codeUrl: 'https://github.com/MarcosLesca/mascotas-social-platform'
  },
  {
    name: 'LYM Desarrollo Web',
    description: 'Sitio institucional real con dominio propio para agencia web. Optimización de performance, cache busting, integración con Google Search Console.',
    tags: ['HTML', 'CSS', 'JS', 'Python'],
    public: true,
    demoUrl: 'https://lymdesarrolloweb.com.ar/',
    codeUrl: 'https://github.com/Loa-FitDev/Pag-MayLo'
  },
  {
    name: 'Concesionario Premium',
    description: 'Catálogo de vehículos de alta gama con carga optimizada y filtros avanzados para una experiencia de usuario premium.',
    tags: ['Next.js', 'TypeScript', 'Shell'],
    public: false
  },
  {
    name: 'SaaS Gestión de Salones',
    description: 'Plataforma de gestión de turnos y pagos para salones de estética con recordatorios automáticos e interfaz intuitiva.',
    tags:['Next.js', 'Postgre SQL', 'Prisma ORM', 'Docker', 'Vercel'],
    public: true,
    demoUrl: 'https://salon-management-platform-frontend.vercel.app/',
    codeUrl: 'https://github.com/MarcosLesca/salon-management-platform'
  }
];
---

<section id="projects" class="py-24 px-6 bg-bg-secondary">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="flex items-baseline gap-4 mb-16">
      <h2 class="text-4xl font-mono font-bold tracking-tight uppercase">Projects</h2>
      <span class="font-mono text-xs text-[#ee9800]/40 uppercase">Selected_Output</span>
    </div>

    <!-- Agronorte Section -->
    <div class="mb-20">
      <div class="flex items-center justify-between mb-8">
        <div class="flex items-center gap-4">
          <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
          <h3 class="font-mono text-lg font-bold uppercase tracking-[0.2em]">// Agronorte · John Deere</h3>
          <div class="hidden sm:block h-[1px] w-32 bg-border"></div>
        </div>
        <span class="bg-accent/20 border border-accent/40 text-accent px-3 py-1 font-mono text-[10px] uppercase tracking-widest">Empleo actual</span>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-px bg-border border border-border">
        {agronorteProjects.map(project => (
          <div class="bg-bg-card p-5 flex flex-col border border-border">
            <div class="mb-3">
              {project.confidential && (
                <span class="text-[9px] font-mono text-text-muted uppercase flex items-center gap-1.5 opacity-70">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                  </svg>
                  Confidencial
                </span>
              )}
            </div>
            <h4 class="text-base font-bold mb-2">{project.name}</h4>
            <p class="text-text-muted text-xs mb-4 flex-grow">{project.description}</p>
            <div class="flex flex-wrap gap-1.5">
              {project.tags.map(tag => (
                <span class="text-[8px] font-mono text-accent bg-accent/5 px-1.5 py-0.5 border border-accent/10 uppercase">{tag}</span>
              ))}
            </div>
          </div>
        ))}
        
        <!-- Stat Card -->
        <div class="bg-bg-card p-5 flex flex-col justify-center border border-accent/10">
          <div class="text-accent mb-3">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <p class="text-[10px] font-mono text-accent/70 uppercase leading-relaxed">
            +40% de eficiencia en procesos de importación y ahorro de 20hs/semana mediante automatización.
          </p>
        </div>
      </div>
      
      <div class="mt-4 flex justify-end">
        <p class="text-[10px] font-mono text-text-muted/40 uppercase tracking-tighter">System_Integrity: 100% // Area: Repuestos_Core</p>
      </div>
    </div>

    <!-- Featured Projects -->
    <div class="mb-20">
      <div class="flex items-center gap-4 mb-8">
        <svg class="w-6 h-6 text-[#ee9800]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
        </svg>
        <h3 class="font-mono text-lg font-bold uppercase tracking-[0.2em]">Featured Projects</h3>
        <div class="flex-grow h-[1px] bg-border"></div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-border border border-border">
        {featuredProjects.map(project => (
          <div class="bg-bg-card p-8 group relative">
            <div class="flex justify-between items-start mb-4">
              {project.public ? (
                <span class="bg-[#ee9800]/10 border border-[#ee9800]/20 px-3 py-1 text-[10px] font-mono text-[#ee9800] uppercase">Público</span>
              ) : (
                <span class="bg-bg-card-hover px-3 py-1 text-[10px] font-mono text-text-muted uppercase flex items-center gap-2">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                  </svg>
                  Repositorio privado
                </span>
              )}
              {project.public && (
                <div class="flex gap-3">
                  <a href={project.codeUrl} class="text-text-muted hover:text-[#ee9800] transition-colors">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                    </svg>
                  </a>
                  <a href={project.demoUrl} class="text-text-muted hover:text-[#ee9800] transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  </a>
                </div>
              )}
            </div>
            <h4 class="text-2xl font-bold mb-3">{project.name}</h4>
            <p class="text-text-muted text-sm mb-5 leading-relaxed">{project.description}</p>
            <div class="flex flex-wrap gap-2">
              {project.tags.map(tag => (
                <span class="text-[10px] font-mono text-[#ee9800] border border-[#ee9800]/20 px-2 py-1 uppercase">{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Academic Projects -->
    <div>
      <div class="flex items-center gap-4 mb-8">
        <svg class="w-6 h-6 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
        </svg>
        <h3 class="font-mono text-sm font-bold uppercase tracking-[0.2em] text-text-muted">Academic Projects</h3>
        <div class="flex-grow h-[1px] bg-border"></div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-bg-card p-6 border border-border">
          <span class="text-[9px] font-mono text-[#ee9800] uppercase mb-3 block">Proyecto académico</span>
          <h5 class="font-bold text-sm mb-2">Sistema RFID — Control de Acceso</h5>
          <p class="text-text-muted text-xs mb-3">Prototipo de control de acceso con tecnología RFID. Frontend + API server propios.</p>
          <div class="text-[9px] font-mono text-[#ee9800]/60 uppercase">Nestjs · MySQL</div>
        </div>
        <div class="bg-bg-card p-6 border border-border">
          <span class="text-[9px] font-mono text-[#ee9800] uppercase mb-3 block">Proyecto académico</span>
          <h5 class="font-bold text-sm mb-2">Sistema de Colectivos</h5>
          <p class="text-text-muted text-xs mb-3">Frontend + backend para gestión de líneas de colectivos y trazabilidad de rutas.</p>
          <div class="text-[9px] font-mono text-[#ee9800]/60 uppercase">Angular · TypeScript · JS · Express · MongoDB</div>
        </div>
        <div class="bg-bg-card p-6 border border-border">
          <span class="text-[9px] font-mono text-[#ee9800] uppercase mb-3 block">Proyecto académico</span>
          <h5 class="font-bold text-sm mb-2">LeonesApp — Club Deportivo</h5>
          <p class="text-text-muted text-xs mb-3">Suite de aplicaciones (móvil y desktop) para gestión integral de club deportivo.</p>
          <div class="text-[9px] font-mono text-[#ee9800]/60 uppercase">C# · .NET MAUI · WinForms</div>
        </div>
      </div>
    </div>
  </div>
</section>
