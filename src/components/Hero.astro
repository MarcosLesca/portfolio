---
const perfilImage = "./perfil_recortada.png";
const cvES = "./cv/MarcosLescano_CV_ES.pdf";
const cvEN = "./cv/MarcosLescano_CV_EN.pdf";
---

<section class="min-h-screen flex items-center pt-20 pb-12">
  <div class="max-w-7xl mx-auto px-6 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center">
      
      <!-- Texto principal -->
      <div class="lg:col-span-7">
        <div class="flex items-center gap-3 mb-6 animate-fade-in">
          <span class="h-[1px] w-12 bg-accent"></span>
          
        </div>
        
        <h1 class="text-6xl md:text-7xl lg:text-8xl font-mono font-bold leading-none mb-6 tracking-tight animate-fade-in animate-fade-in-delay-1">
          MARCOS<br />
          <span class="text-accent">LESCANO</span>
        </h1>
        
        <!-- Avatar mobile - entre cita y título -->
        <div class="lg:hidden flex justify-center mb-6">
          <div class="relative bg-bg-card border border-border p-3 w-36">
            <div class="absolute -top-2 -left-2 w-4 h-4 border-t-2 border-l-2 border-accent"></div>
            <div class="absolute -bottom-2 -right-2 w-4 h-4 border-b-2 border-r-2 border-accent"></div>
            <div class="w-32 h-32 mx-auto overflow-hidden rounded-sm">
              <img 
                src={perfilImage} 
                alt="Marcos Lescano" 
                class="w-full h-full object-cover"
              />
            </div>
          </div>
        </div>
        
        <p class="text-lg font-mono text-accent mb-8 uppercase tracking-wide animate-fade-in animate-fade-in-delay-3">
          Fullstack Software Engineer <span class="text-text-dim px-2">//</span> Autodidacta
         </p>
        
        <div class="flex flex-wrap gap-4 animate-fade-in animate-fade-in-delay-4">
          <a 
            href="#projects" 
            class="bg-accent text-bg-primary px-8 py-4 font-mono font-bold text-sm tracking-widest uppercase hover:bg-accent-hover transition-colors flex items-center gap-3"
          >
            Ver Proyectos
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          
          <!-- Download CV Dropdown -->
          <div class="relative group" id="cv-dropdown-container">
            <button 
              id="cv-dropdown-btn"
              class="border border-border text-text px-8 py-4 font-mono font-bold text-sm tracking-widest uppercase hover:border-accent hover:text-accent transition-colors flex items-center gap-2"
            >
              Descargar CV
              <svg class="w-4 h-4 transition-transform duration-200" id="cv-dropdown-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <!-- Dropdown menu -->
            <div id="cv-dropdown-menu" class="absolute top-full left-0 mt-2 w-48 bg-bg-card border border-border opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
              <a 
                href={cvES} 
                download="MarcosLescano_CV.pdf"
                class="block px-4 py-3 font-mono text-sm text-text-muted hover:text-accent hover:bg-bg-primary transition-colors border-b border-border"
              >
                🇪🇸 Español
              </a>
              <a 
                href={cvEN} 
                download="MarcosLescano_CV_EN.pdf"
                class="block px-4 py-3 font-mono text-sm text-text-muted hover:text-accent hover:bg-bg-primary transition-colors"
              >
                🇬🇧 English
              </a>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Imagen/Avatar - Solo desktop -->
      <div class="lg:col-span-5 hidden lg:block">
        <div class="relative bg-bg-card border border-border p-4">
          <div class="absolute -top-2 -left-2 w-6 h-6 border-t-2 border-l-2 border-accent"></div>
          <div class="absolute -bottom-2 -right-2 w-6 h-6 border-b-2 border-r-2 border-accent"></div>
          
          <div class="aspect-square overflow-hidden">
            <img 
              src={perfilImage} 
              alt="Marcos Lescano" 
              class="w-full h-full object-cover"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const dropdownBtn = document.getElementById('cv-dropdown-btn');
  const dropdownMenu = document.getElementById('cv-dropdown-menu');
  const dropdownArrow = document.getElementById('cv-dropdown-arrow');
  const dropdownContainer = document.getElementById('cv-dropdown-container');

  let isOpen = false;

  // Toggle dropdown on click (works on both mobile and desktop)
  dropdownBtn?.addEventListener('click', (e) => {
    e.preventDefault();
    e.stopPropagation();
    isOpen = !isOpen;
    
    if (isOpen) {
      dropdownMenu?.classList.remove('opacity-0', 'invisible');
      dropdownMenu?.classList.add('opacity-100', 'visible');
      dropdownArrow?.classList.add('rotate-180');
    } else {
      dropdownMenu?.classList.add('opacity-0', 'invisible');
      dropdownMenu?.classList.remove('opacity-100', 'visible');
      dropdownArrow?.classList.remove('rotate-180');
    }
  });

  // Close dropdown when clicking outside
  document.addEventListener('click', (e) => {
    if (isOpen && dropdownContainer && !dropdownContainer.contains(e.target)) {
      isOpen = false;
      dropdownMenu?.classList.add('opacity-0', 'invisible');
      dropdownMenu?.classList.remove('opacity-100', 'visible');
      dropdownArrow?.classList.remove('rotate-180');
    }
  });

  // Close dropdown on escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) {
      isOpen = false;
      dropdownMenu?.classList.add('opacity-0', 'invisible');
      dropdownMenu?.classList.remove('opacity-100', 'visible');
      dropdownArrow?.classList.remove('rotate-180');
    }
  });
</script>
