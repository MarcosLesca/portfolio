---
const education = [
  {
    period: '2021 — 2024',
    institution: 'Instituto Superior de Profesorado N°20',
    location: 'San Justo, Santa Fe',
    title: 'Técnico Superior en Soporte de Infraestructura de la Información',
    description: 'Formación especializada en administración de sistemas, redes, soporte técnico y gestión de infraestructura IT.',
    tags: ['Infraestructura', 'Redes', 'Soporte Técnico'],
    colorClass: 'amber'
  },
  {
    period: '2021 — 2023',
    institution: 'Instituto Superior de Profesorado N°20',
    location: 'San Justo, Santa Fe',
    title: 'Técnico Superior en Desarrollo de Software',
    description: 'Formación en análisis, diseño y desarrollo de sistemas de software, metodologías ágiles y buenas prácticas de programación.',
    tags: ['Desarrollo', 'Software', 'Metodologías Ágiles'],
    colorClass: 'accent'
  }
];

const getColors = (colorClass: string) => {
  if (colorClass === 'accent') {
    return {
      borderL: 'border-l-accent',
      borderAll: 'border-accent',
      text: 'text-accent',
      borderAlpha: 'border-accent/20'
    };
  }
  if (colorClass === 'amber') {
    return {
      borderL: 'border-l-[#ee9800]',
    borderAll: 'border-[#ee9800]',
    text: 'text-[#ee9800]',
    borderAlpha: 'border-[#ee9800]/20'
    };
  }
  return {
    borderL: 'border-l-[#ee9800]',
    borderAll: 'border-[#ee9800]',
    text: 'text-[#ee9800]',
    borderAlpha: 'border-[#ee9800]/20'
  };
};
---

<section id="education" class="py-24 px-6 bg-bg-secondary">
  <div class="max-w-7xl mx-auto">
    <div class="flex justify-between items-end mb-16">
      <div>
        <h2 class="text-4xl font-mono font-bold tracking-tight mb-4 uppercase">Formación Académica</h2>
        <div class="w-24 h-1 bg-accent"></div>
      </div>
      <div class="hidden md:block">
        <span class="font-mono text-xs text-text-muted uppercase tracking-widest">Log: Academic_Background</span>
      </div>
    </div>
    
    <div class="space-y-6">
      {education.map((edu) => {
        const colors = getColors(edu.colorClass);
        return (
        <div class={`group bg-bg-card hover:bg-bg-card-hover transition-colors p-8 border border-border hover:${colors.borderAll} border-l-4 ${colors.borderL} grid grid-cols-1 md:grid-cols-12 gap-8`}>
          <div class="md:col-span-3">
            <span class={`font-mono text-sm ${colors.text}`}>
              {edu.period}
            </span>
            <h3 class="text-xl font-bold mt-2">{edu.institution}</h3>
            <p class="text-text-muted text-sm mt-1">{edu.location}</p>
          </div>
          <div class="md:col-span-9">
            <h4 class="text-lg font-mono text-text mb-4 uppercase tracking-tight">{edu.title}</h4>
            <p class="text-text-muted leading-relaxed max-w-3xl">
              {edu.description}
            </p>
            <div class="mt-6 flex flex-wrap gap-2">
              {edu.tags.map(tag => (
                <span class={`bg-bg-card-hover px-3 py-1 text-[10px] font-mono ${colors.text} uppercase ${colors.borderAlpha}`}>
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </div>
        );
      })}
    </div>
  </div>
</section>
