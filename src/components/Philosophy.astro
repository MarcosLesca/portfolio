---
const principles = [
  {
    icon: 'psychology',
    title: 'Aprendo haciendo.',
    description: 'La teoría es solo el mapa; el código real es el terreno. Mi crecimiento se basa en la experimentación constante.',
    color: 'accent'
  },
  {
    icon: 'speed',
    title: 'Momentum antes que perfección.',
    description: 'Prefiero iterar sobre algo funcional que soñar con algo perfecto que nunca llega a producción.',
    color: 'secondary'
  },
  {
    icon: 'terminal',
    title: 'Código que resuelve problemas reales.',
    description: 'El software es una herramienta, no el fin. Si no ayuda al usuario o al negocio, es desperdicio.',
    color: 'accent'
  },
  {
    icon: 'view_in_ar',
    title: 'Visión completa: de hardware a producto.',
    description: 'Entender cómo fluyen los electrones ayuda a escribir mejores abstracciones en el frontend.',
    color: 'secondary'
  }
];

const icons: Record<string, string> = {
  psychology: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  speed: 'M13 10V3L4 14h7v7l9-11h-7z',
  terminal: 'M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
  view_in_ar: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4'
};
---

<section id="philosophy" class="py-24 px-6">
  <div class="max-w-7xl mx-auto bg-bg-card border border-border p-8 md:p-12">
    <div class="mb-12">
      <h2 class="text-4xl font-mono font-bold tracking-tight uppercase mb-2">Filosofía</h2>
      <p class="text-accent font-mono text-xs uppercase tracking-widest">Guiding Principles of Development</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
      {principles.map(principle => (
        <div class="flex gap-5">
          <div class={principle.color === 'accent' ? 'text-accent' : 'text-secondary'}>
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icons[principle.icon]} />
            </svg>
          </div>
          <div>
            <h4 class="font-bold text-lg mb-2 uppercase tracking-tight">{principle.title}</h4>
            <p class="text-text-muted text-sm leading-relaxed">{principle.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
